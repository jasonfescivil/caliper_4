*.log
logs/

# Testing
.coverage
.pytest_cache/
.tox/
.nox/
htmlcov/

# Documentation
docs/_build/

# Large files that shouldn't be in image
knowledge_base/
outputs/
*.pdf
*.docx
*.xlsx
*.zip
*.tar.gz

# Temporary files
tmp/
temp/
.tmp/

# Development files
.env.example
README*.md
CHEATSHEET*
test_*.txt
TEST_*

# Keep essential files
!requirements-lightweight.txt
!test_question.txt

# Old/backup files
*~
*.bak
*.orig
