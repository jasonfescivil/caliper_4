{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClaimsV1",
  "type": "object",
  "required": ["type", "version", "claims"],
  "properties": {
    "type": { "const": "claims" },
    "version": { "const": 1 },
    "doc_path": { "type": "string" },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "span"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "heading": { "type": ["string", "null"] },
          "claim_type": { "type": ["string", "null"] },
          "span": {
            "type": "object",
            "required": ["start", "end"],
            "properties": {
              "start": { "type": "integer" },
              "end": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
