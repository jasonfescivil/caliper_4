# Copy to .env and fill real values. Do NOT commit .env.

# App
APP_NAME=Caliper
LOG_LEVEL=INFO

# Provider selection
DEFAULT_PROVIDER=openai

# OpenAI (or Azure OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=...
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Google Gemini
GOOGLE_API_KEY=...
GOOGLE_MODEL=gemini-2.5-pro-preview

# X.AI (Grok)
XAI_API_KEY=...
XAI_MODEL=grok-4-fast-reasoning
XAI_API_BASE=https://api.x.ai/v1

# Llama Cloud / LlamaParse
LLAMA_CLOUD_API_KEY=...

# RAG / Vector store (optional)
RAG_VECTORSTORE=weaviate
WEAVIATE_URL=http://weaviate:8080

# Retrieval defaults
RETRIEVAL_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.6
USE_HYBRID_SEARCH=true
HYBRID_ALPHA=0.7

# Chunking
CHUNK_SIZE=2000
CHUNK_OVERLAP=400

# Embeddings / reranking (optional)
EMBEDDING_PROVIDER=openai
COHERE_API_KEY=
USE_RERANKING=false
RERANKING_MODEL=cohere

# Cloud index IDs (examples — replace with your IDs)
FEDERAL_BASE_ID=
FEDERAL_SUMMARY_ID=
STATE_BASE_ID=
STATE_SUMMARY_ID=
DESIGN_BASE_ID=
DESIGN_SUMMARY_ID=

